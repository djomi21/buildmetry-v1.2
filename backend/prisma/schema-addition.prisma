//
// 1. In your existing "Project" model, add this line:
//      contracts  Contract[]
//
// 2. In your existing "Estimate" model, add this line:
//      contracts  Contract[] @relation("ContractEstimate")
//
// If you skip this, Prisma will throw an error on generate.
